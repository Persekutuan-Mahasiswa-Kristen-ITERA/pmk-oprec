{
    "headers": [
        {
            "source": "/(.*)\\.(?:woff|woff2|eot|ttf|json|png|jpg|jpeg|gif|webp|avif|svg|ico)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}